    "Wello reste utilisable en saisie manuelle. Les lignes à réparer ouvrent les Réglages iOS." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wello bleibt mit manueller Eingabe nutzbar. Zu behebende Zeilen öffnen die iOS-Einstellungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wello stays usable with manual entry. Lines to fix open iOS Settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wello sigue siendo utilizable con entrada manual. Las líneas por corregir abren los Ajustes de iOS."
          }
        },
        "it" : {
