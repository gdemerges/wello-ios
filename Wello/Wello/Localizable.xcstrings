    "Vise un apport plus élevé pour la prévention des calculs. À régler selon avis médical." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zielt auf eine höhere Zufuhr zur Steinvorbeugung. Nach ärztlichem Rat anpassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aims for a higher intake to help prevent stones. Adjust per medical advice."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Busca una ingesta mayor para prevenir cálculos. Ajusta según consejo médico."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Punta a un apporto maggiore per prevenire i calcoli. Da regolare secondo parere medico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "結石予防のため多めの摂取を目指します。医師の助言に従って調整してください。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Busca uma ingestão maior para prevenir cálculos. Ajuste conforme orientação médica."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为预防结石而设定更高摄入量。请遵医嘱调整。"
          }
        }
      }
    },
