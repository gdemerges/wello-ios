            "value": "Sets your hydration base from EFSA reference intakes (2000 ml male / 1600 ml female)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fija tu base de hidratación según las ingestas de referencia EFSA (2000 ml hombre / 1600 ml mujer)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Legt deine Hydrationsbasis nach den EFSA-Referenzwerten fest (2000 ml Mann / 1600 ml Frau)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fissa la tua base di idratazione secondo gli apporti di riferimento EFSA (2000 ml uomo / 1600 ml donna)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Define sua base de hidratação com base nas ingestões de referência da EFSA (2000 ml homem / 1600 ml mulher)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "EFSAの基準摂取量（男性2000 ml／女性1600 ml）に基づいて水分補給の基準値を設定します。"
          }
        },
        "zh-Hans": {
