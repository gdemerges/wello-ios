            "value": "It sets your hydration base from EFSA reference intakes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fija tu base de hidratación según las ingestas de referencia EFSA."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Er legt deine Hydrationsbasis nach den EFSA-Referenzwerten fest."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fissa la tua base di idratazione secondo gli apporti di riferimento EFSA."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Define sua base de hidratação com base nas ingestões de referência da EFSA."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "EFSAの基準摂取量からあなたの水分補給の基準値を決めます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "根据 EFSA 参考摄入量确定你的补水基准。"
          }
        }
      }
    },
