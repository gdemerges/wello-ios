    "Total du jour : %lld ml — balaie une prise pour la supprimer.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Today's total: %lld ml — swipe an entry to delete it."
          }
        },
        "es": {
