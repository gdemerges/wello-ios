    "Certains services ne sont pas actifs. Tout refus est géré : l'app reste pleinement utilisable." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einige Dienste sind inaktiv. Jede Ablehnung wird berücksichtigt: Die App bleibt voll nutzbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Some services are inactive. Every denial is handled: the app stays fully usable."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Algunos servicios no están activos. Cada rechazo se gestiona: la app sigue siendo totalmente utilizable."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alcuni servizi non sono attivi. Ogni rifiuto è gestito: l'app resta pienamente utilizzabile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一部のサービスが無効です。すべての拒否に対応しており、アプリは問題なく使えます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alguns serviços não estão ativos. Cada recusa é tratada: o app continua totalmente utilizável."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "部分服务未启用。每一次拒绝都已处理：应用仍可完全使用。"
          }
        }
      }
    },
    "Ces horaires indiquent la dernière lecture locale utilisée par Wello. En cas de refus, l'app garde un repli neutre et reste utilisable." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Zeiten zeigen die letzte von Wello genutzte lokale Auslesung. Bei Ablehnung behält die App einen neutralen Rückfallwert und bleibt nutzbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "These times show the last local reading used by Wello. If access is denied, the app keeps a neutral fallback and stays usable."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estas horas indican la última lectura local utilizada por Wello. Si se deniega el acceso, la app mantiene un valor neutro de reserva y sigue siendo utilizable."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questi orari indicano l'ultima lettura locale usata da Wello. In caso di rifiuto, l'app mantiene un valore neutro di riserva e resta utilizzabile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これらの時刻は、Wello が使用した最後のローカル取得を示します。拒否された場合でも、アプリは中立的な代替値を保持し、引き続き利用できます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estes horários indicam a última leitura local usada pelo Wello. Em caso de recusa, o app mantém um valor neutro de reserva e continua utilizável."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这些时间显示 Wello 使用的最后一次本地读取。若被拒绝，应用会保留中性的回退值并继续可用。"
          }
        }
      }
    },
    "Cette semaine" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Woche"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This week"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta semana"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa settimana"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今週"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta semana"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
